// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())

  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  // 2FA/TOTP
  totpSecret  String?  // Encrypted
  totpEnabled Boolean  @default(false)

  // Account security
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // KYC/Compliance (for future use)
  dateOfBirth     DateTime?
  nationalId      String?     @unique
  idType          String?     // PASSPORT, NATIONAL_ID, DRIVER_LICENSE
  address         String?
  city            String?
  country         String?
  postalCode      String?
  accountTier     String      @default("BASIC") // BASIC, STANDARD, GOLD
  kycStatus       String      @default("PENDING") // PENDING, APPROVED, REJECTED
  kycVerifiedAt   DateTime?
  kycRejectionReason String?

  accounts Account[]
}

model Account {
  id            String   @id @default(uuid())
  userId        String
  accountNumber String   @unique
  currency      String   @default("GMD")
  balance       Float    @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  ledgerEntries       LedgerEntry[]
  preferences         AccountPreference?
  beneficiaries       Beneficiary[]
  standingOrdersFrom  StandingOrder[] @relation("StandingOrderFrom")
  standingOrdersTo    StandingOrder[] @relation("StandingOrderTo")
  transactionLimits   TransactionLimit?
  alerts              AccountAlert[]
  holds               AccountHold[]
  statements          AccountStatement[]
  spendingCategories  SpendingCategory[]

  @@index([userId])
  @@index([status])
}

model Transaction {
  id        String   @id @default(uuid())
  reference String   @unique
  type      String
  amount    Float
  currency  String   @default("GMD")
  status    String
  riskScore Int      @default(0)
  riskLevel String   @default("LOW")
  isFlagged Boolean  @default(false)
  fraudReasons String[] @default([])
  fraudReviewStatus String? // PENDING_REVIEW, APPROVED, REJECTED
  fraudReviewNote String?
  fraudReviewedBy String?
  fraudReviewedAt DateTime?
  createdAt DateTime @default(now())

  ledgerEntries     LedgerEntry[]
  spendingCategories SpendingCategory[]

  @@index([status])
  @@index([createdAt])
  @@index([isFlagged])
  @@index([fraudReviewStatus])
  @@index([riskScore])
}

model LedgerEntry {
  id            String   @id @default(uuid())
  transactionId String
  accountId     String
  entryType     String
  amount        Float
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // e.g. AUTH.LOGIN, ACCOUNT.CREATE, TRANSACTION.TRANSFER
  resource   String?  
  resourceId String?
  method     String? 
  path       String?  // request path
  statusCode Int?
  ipAddress  String?
  userAgent  String?
  metadata   Json?    // amount, currency, reference, etc.
  createdAt  DateTime @default(now())
}

model IdempotencyKey {
  id          String   @id @default(uuid())
  key         String   @unique
  requestHash String
  response    String?
  createdAt   DateTime @default(now())
}

model AccountPreference {
  id                        String   @id @default(uuid())
  accountId                 String   @unique
  notificationsEnabled      Boolean  @default(true)
  lowBalanceThreshold       Float    @default(1000)
  statementFrequency        String   @default("MONTHLY")
  cardlessWithdrawalAllowed Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Beneficiary {
  id        String   @id @default(uuid())
  accountId String
  name      String
  bankCode  String
  bankAccount String
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([deletedAt])
}

model StandingOrder {
  id                  String   @id @default(uuid())
  fromAccountId       String
  toAccountId         String
  amount              Float
  frequency           String   // DAILY, WEEKLY, MONTHLY
  nextExecutionDate   DateTime
  startDate           DateTime
  endDate             DateTime?
  status              String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  executionCount      Int      @default(0)
  lastExecutionDate   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  fromAccount Account @relation("StandingOrderFrom", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount   Account @relation("StandingOrderTo", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([status])
  @@index([nextExecutionDate])
}

model TransactionLimit {
  id                       String   @id @default(uuid())
  accountId                String   @unique
  singleTransactionMaximum Float?
  dailyWithdrawalLimit     Float?
  dailyTransactionCount    Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model AccountAlert {
  id        String   @id @default(uuid())
  accountId String
  type      String   // LOW_BALANCE, LARGE_DEBIT, UNUSUAL_ACTIVITY, STATEMENT_READY
  threshold Float?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([type])
}

model AccountHold {
  id        String   @id @default(uuid())
  accountId String
  amount    Float
  reason    String   // COMPLIANCE_CHECK, FRAUD_INVESTIGATION, COURT_ORDER
  expiryDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiryDate])
}

model AccountStatement {
  id             String   @id @default(uuid())
  accountId      String
  periodStart    DateTime
  periodEnd      DateTime
  openingBalance Float
  closingBalance Float
  totalCredits   Float
  totalDebits    Float
  transactionCount Int    @default(0)
  createdAt      DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([periodStart])
  @@index([periodEnd])
}

model SpendingCategory {
  id            String   @id @default(uuid())
  transactionId String
  accountId     String
  category      String
  amount        Float
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([category])
  @@index([createdAt])
}