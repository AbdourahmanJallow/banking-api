{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@prisma/*": ["./src/generated/prisma/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "tests"],
    "tsc-alias": {
        "resolveFullPaths": true,
        "resolveFullExtension": ".js"
    }
}
